# Auto tries to use the same host as the Expo development server.
EXPO_PUBLIC_API_URL=auto

# If auto does not work, use the PC's Wi-Fi/LAN IPv4 address.
# Example:
# EXPO_PUBLIC_API_URL=http://192.168.1.26:8000

# For Android emulator, this is usually:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# For web or local desktop testing:
# EXPO_PUBLIC_API_URL=http://localhost:8000

# EXPO_PUBLIC_API_URL=http://YOUR_PC_LAN_IP:8000
